# Copie este arquivo para .env.local e preencha com as credenciais do seu projeto Supabase.
# Dashboard: https://supabase.com/dashboard → seu projeto → Settings → API Keys

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Aceita QUALQUER UM dos dois (use o que o Supabase te mostrar):
#   - Formato novo: sb_publishable_...  → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#   - Formato legado: eyJ... (JWT)       → NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --------------------------------------------------------------
# Push notifications (VAPID — Web Push)
# --------------------------------------------------------------
# Gerar local: `npx web-push generate-vapid-keys`
# A public vai no browser. A private FICA SO nas Edge Functions.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BB-mCUA3qqLb_AIi13WH1814cIiD1tWLrwGdPh6jFMqA3wDioopKgQYTSvIFeSVxHYMRdm00vrSd78MHF0dACtU

# No dashboard do Supabase → Edge Functions → Secrets, setar:
#   VAPID_PUBLIC_KEY  = mesma chave publica acima
#   VAPID_PRIVATE_KEY = ru4pIMUL8IS6HuzSqOROdBFYby_O-1jAtYHq3Yd4fYI
#   VAPID_SUBJECT     = mailto:contato@mindpractice.app
