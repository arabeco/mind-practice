# Copie este arquivo para .env.local e preencha com as credenciais do seu projeto Supabase.
# Dashboard: https://supabase.com/dashboard → seu projeto → Settings → API Keys

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Aceita QUALQUER UM dos dois (use o que o Supabase te mostrar):
#   - Formato novo: sb_publishable_...  → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#   - Formato legado: eyJ... (JWT)       → NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
