        { "text": "Respondo com outra pergunta.", "subtext": "Devolve", "tone": "provocativo", "weights": { "filtro": 3, "vigor": -1, "harmonia": -1, "desapego": -1 }, "feedback": "Voce mantem o controle do campo." }
