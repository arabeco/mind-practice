        { "text": "Digo sim e depois me remoo.", "subtext": "Nao sabe negar", "tone": "evasivo", "weights": { "harmonia": 3, "vigor": -2, "filtro": -1 }, "feedback": "Voce ganha paz — perde em outra moeda." },
        { "text": "Invento uma razao pra nao poder.", "subtext": "Nao desaponta", "tone": "evasivo", "weights": { "filtro": 3, "presenca": -2, "vigor": -1 }, "feedback": "Voce evita a cena mas paga em verdade." }
      ]
    },
    {
