      "sceneHook": "Vizinho encheu o saco de novo",
      "metadata": { "tensao": 3, "ambiente": "Privado", "relacao": "Par", "aposta": "Paz Emocional", "pilar": "propriedade" },
      "slides": [{ "tipo": "evento", "texto": "Terceira noite de som alto do vizinho. Voce..." }],
