        { "text": "Coloco abafador e durmo.", "subtext": "Resolve sozinho", "tone": "evasivo", "weights": { "desapego": 3, "vigor": -2, "presenca": -1 }, "feedback": "Voce cuida do seu sono sem guerra." },
