        { "text": "Comento alto pra eles ouvirem.", "subtext": "Passivo-agressivo", "tone": "provocativo", "weights": { "vigor": 3, "filtro": -1, "harmonia": -1, "desapego": -1 }, "feedback": "Voce sinaliza sem encarar direto." }
      ]
    },
    {
