        { "text": "Passo pro meu gestor: 'Ta rolando isso.'", "subtext": "Escala", "tone": "neutro", "weights": { "filtro": 3, "vigor": -1, "harmonia": -1, "desapego": -1 }, "feedback": "Voce aciona o sistema certo." }
      ]
