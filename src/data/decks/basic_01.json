  "questions": [
    {
      "id": "q1",
      "type": "NORMAL",
      "sceneHook": "De modo geral",
      "metadata": {
        "tensao": 2,
        "ambiente": "Publico",
        "relacao": "Desconhecido",
        "aposta": "Tempo",
        "pilar": "propriedade"
      },
      "slides": [
        {
          "tipo": "evento",
          "texto": "Quando alguem furra sua vez na fila, voce..."
        }
      ],
      "options": [
        {
          "text": "Fala na hora, sem drama.",
          "subtext": "Marca territorio",
          "tone": "pragmatico",
          "weights": { "vigor": 3, "presenca": 2, "harmonia": -1 },
          "feedback": "Direto. Voce nao deixa passar."
        },
        {
          "text": "Finge que nao vi. Nao vale a energia.",
          "subtext": "Deixa pra la",
          "tone": "evasivo",
          "weights": { "desapego": 3, "filtro": 1, "vigor": -1, "presenca": -2 },
          "feedback": "Escolheu a paz. Nem todo combate interessa."
        },
        {
          "text": "Depende do dia — as vezes falo, as vezes passo.",
          "subtext": "Leitura do momento",
          "tone": "neutro",
          "weights": { "filtro": 2, "harmonia": 1, "presenca": -1 },
          "feedback": "Voce lê o momento antes de reagir."
        }
      ]
    },
    {
      "id": "q2",
      "type": "NORMAL",
      "sceneHook": "Alguem proximo de voce — amigo, familia",
      "metadata": {
        "tensao": 3,
        "ambiente": "Publico",
        "relacao": "Proximo",
        "aposta": "Paz Emocional",
        "pilar": "ego",
        "proximidade": "alta"
      },
      "slides": [
        {
          "tipo": "evento",
          "texto": "...faz uma piada as suas custas na frente dos outros."
        }
      ],
      "options": [
        {
          "text": "Devolvo com outra piada. Jogo junto.",
          "subtext": "Joga o jogo",
          "tone": "pragmatico",
          "weights": { "desapego": 2, "harmonia": 2, "vigor": 1, "filtro": -1 },
          "feedback": "Voce nao leva pro pessoal."
        },
        {
          "text": "Corto seco: 'Nao curti.'",
          "subtext": "Marca o limite",
          "tone": "pragmatico",
          "weights": { "vigor": 3, "presenca": 2, "harmonia": -2 },
          "feedback": "Amigo ou nao, voce tem limite claro."
        },
        {
          "text": "Fico quieto ali, converso em particular depois.",
          "subtext": "Resolve offline",
          "tone": "neutro",
          "weights": { "filtro": 3, "harmonia": 2, "presenca": -1, "desapego": -1 },
          "feedback": "Voce separa briga publica de resolucao."
        }
      ]
    },
    {
      "id": "q3",
      "type": "NORMAL",
      "sceneHook": "Transito, fim de expediente, voce cansado",
      "metadata": {
        "tensao": 3,
        "ambiente": "Publico",
        "relacao": "Desconhecido",
        "aposta": "Paz Emocional",
        "pilar": "ego"
      },
      "slides": [
        {
          "tipo": "evento",
          "texto": "Carro do lado fecha voce feio. O motorista ainda te xinga."
        }
      ],
      "options": [
        {
          "text": "Buzino e devolvo o dedo. Nao fica assim.",
          "subtext": "Reage na hora",
          "tone": "pragmatico",
          "weights": { "vigor": 3, "presenca": 1, "harmonia": -3, "filtro": -2 },
          "feedback": "Sangue quente. Nao engole."
        },
        {
          "text": "Solto um palavrao so pra mim e sigo.",
          "subtext": "Libera e passa",
          "tone": "neutro",
          "weights": { "filtro": 2, "desapego": 2, "vigor": -1 },
          "feedback": "Descarrega por dentro, segue a vida."
        },
        {
          "text": "Nem ligo. Gente assim nao merece meu minuto.",
          "subtext": "Totalmente desapegado",
          "tone": "evasivo",
          "weights": { "desapego": 3, "harmonia": 1, "vigor": -2, "presenca": -2 },
          "feedback": "Voce nao alimenta briga de estranho."
        }
      ]
    },
    {
      "id": "q4",
      "type": "NORMAL",
      "sceneHook": "Grupo de amigos — gente que voce confia",
      "metadata": {
        "tensao": 2,
        "ambiente": "Social",
        "relacao": "Proximo",
        "aposta": "Imagem Publica",
        "pilar": "pertencimento"
      },
      "slides": [
        {
          "tipo": "evento",
          "texto": "Todo mundo concorda com algo que voce acha uma besteira. O que faz?"
        }
      ],
      "options": [
        {
          "text": "Falo. Prefiro discordar do que fingir.",
          "subtext": "Voz propria",
          "tone": "pragmatico",
          "weights": { "vigor": 2, "presenca": 3, "harmonia": -1 },
          "feedback": "Voce nao finge so pra caber."
        },
        {
          "text": "Concordo pra manter o clima, penso depois.",
          "subtext": "Mantem a paz",
          "tone": "evasivo",
          "weights": { "harmonia": 3, "desapego": 1, "vigor": -2, "presenca": -2 },
          "feedback": "Voce protege o clima antes da razao."
        },
        {
          "text": "Faco uma pergunta esperta pra eles repensarem.",
          "subtext": "Discorda no esguelha",
          "tone": "neutro",
          "weights": { "filtro": 3, "presenca": 1, "harmonia": 1, "vigor": -1 },
          "feedback": "Voce desmonta sem brigar."
        }
      ]
    },
    {
      "id": "q5",
      "type": "NORMAL",
      "sceneHook": "Dia ruim. Voce ta no limite",
      "metadata": {
        "tensao": 4,
        "ambiente": "Privado",
        "relacao": "Proximo",
        "aposta": "Paz Emocional",
        "pilar": "ego",
        "proximidade": "alta"
      },
      "slides": [
        {
          "tipo": "evento",
          "texto": "Parceiro(a) reclama de algo bobo justo agora. Voce..."
        }
      ],
      "options": [
        {
          "text": "Avisa: 'Hoje nao, tô exausto(a).'",
          "subtext": "Pede espaco",
          "tone": "pragmatico",
          "weights": { "vigor": 1, "presenca": 2, "filtro": 2, "harmonia": -1 },
          "feedback": "Voce nomeia o que sente antes de errar."
        },
        {
          "text": "Engole e responde como se nada fosse.",
          "subtext": "Nao mostra",
          "tone": "evasivo",
          "weights": { "harmonia": 2, "filtro": 1, "vigor": -2, "presenca": -2, "desapego": -1 },
          "feedback": "Voce segura — mas acumula."
        },
        {
          "text": "Estouro. Desconto na outra pessoa.",
          "subtext": "Explode",
          "tone": "pragmatico",
          "weights": { "vigor": 3, "harmonia": -3, "filtro": -3, "presenca": 1 },
          "feedback": "O cansaco virou voz."
        }
      ]
    },
    {
      "id": "q6",
      "type": "NORMAL",
      "sceneHook": "No trabalho — colega que voce mal conhece",
      "metadata": {
        "tensao": 2,
        "ambiente": "Profissional",
        "relacao": "Par",
        "aposta": "Imagem Publica",
        "pilar": "propriedade",
        "proximidade": "baixa"
      },
      "slides": [
        {
          "tipo": "evento",
          "texto": "Ela apresenta como ideia dela algo que voce disse no cafezinho."
        }
      ],
      "options": [
        {
          "text": "Corrige na hora: 'Legal, foi o que falei outro dia ne.'",
          "subtext": "Reclama credito",
          "tone": "pragmatico",
          "weights": { "vigor": 2, "presenca": 3, "harmonia": -1 },
          "feedback": "Voce nao abre mao do que e seu."
        },
        {
          "text": "Deixa passar. Nao vou brigar por isso aqui.",
          "subtext": "Nao vale a briga",
          "tone": "evasivo",
          "weights": { "desapego": 3, "harmonia": 2, "vigor": -2, "presenca": -2 },
          "feedback": "Voce escolhe as batalhas com cuidado."
        },
        {
          "text": "Depois, em privado, pergunto direto pra ela.",
          "subtext": "Resolve offline",
          "tone": "neutro",
          "weights": { "filtro": 3, "vigor": 1, "harmonia": 1, "desapego": -1 },
          "feedback": "Voce enfrenta — mas sem plateia."
        }
      ]
    },
    {
      "id": "q7",
      "type": "NORMAL",
      "sceneHook": "Fim do dia. Cabeca lotada",
      "metadata": {
        "tensao": 2,
        "ambiente": "Privado",
        "relacao": "Desconhecido",
        "aposta": "Paz Emocional",
        "pilar": "ego"
      },
      "slides": [
        {
          "tipo": "evento",
          "texto": "Algo bobo ficou te remoendo desde cedo. Voce..."
        }
      ],
      "options": [
        {
          "text": "Penso ate resolver na cabeca, nem que demore.",
          "subtext": "Mastiga tudo",
          "tone": "neutro",
          "weights": { "filtro": 3, "presenca": 1, "desapego": -2 }
