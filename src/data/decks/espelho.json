      "slides": [{ "tipo": "evento", "texto": "Grupo te chama pra sair. Voce nao tava a fim." }],
      "options": [
        { "text": "Falo a verdade: 'Hoje nao, to cansado(a).'", "subtext": "Verdade crua", "tone": "pragmatico", "weights": { "presenca": 3, "harmonia": -2, "vigor": -1 }, "feedback": "Voce nao inventa desculpa." },
        { "text": "Dou uma desculpa qualquer.", "subtext": "Nao quer explicar", "tone": "evasivo", "weights": { "harmonia": 3, "presenca": -2, "vigor": -1 }, "feedback": "Voce prioriza o clima antes da verdade." },
        { "text": "Vou, mesmo cansado(a). Amigos importam.", "subtext": "Forca a barra", "tone": "protetor", "weights": { "vigor": 3, "desapego": -2, "filtro": -1 }, "feedback": "Voce paga o preco pra estar junto." }
