# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# capacitor (plataformas geradas via `npx cap add`)
# Commitamos android/ pra preservar o plugin nativo StoreBilling (custom).
# Build artifacts ficam excluídos abaixo.
# /android/    ← descomentado intencionalmente
# /ios/        ← descomentado quando adicionar ios
.capacitor/

# Android build artifacts (cache local, não precisa commitar)
/android/.gradle/
/android/.idea/
/android/build/
/android/app/build/
/android/app/release/
/android/local.properties
/android/captures/
/android/app/google-services.json

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude local
.claude/settings.local.json

# supabase CLI temp
supabase/.temp/

.claude/worktrees/
